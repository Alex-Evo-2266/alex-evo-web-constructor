{
  "name": "alex-evo-web-constructor",
  "version": "1.0.30",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "pub": "npm run build && npm version patch && npm publish"
  },
  "main": "./dist/alex-evo-web-constructor.umd.js",
  "module": "./dist/alex-evo-web-constructor.es.js",
  "types": "./dist/index.d.ts",
  "stylelint": {},
  "exports": {
    ".": {
      "import": "./dist/alex-evo-web-constructor.es.js",
      "require": "./dist/alex-evo-web-constructor.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "lucide-react": "*",
    "react": "*",
    "react-dom": "*",
    "react-router-dom": "*"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@vitejs/plugin-react": "^4.3.1",
    "alex-evo-sh-ui-kit": "^1.1.84",
    "eslint": "^9.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "lucide-react": "^0.441.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "sass": "^1.78.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-dts": "^4.2.2",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vitest": "^4.1.0",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "storybook": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.3.0",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-onboarding": "^10.3.0",
    "eslint-plugin-storybook": "^10.3.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
